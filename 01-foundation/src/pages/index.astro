---
import MainLayout from "../layouts/MainLayouts.astro";

// Variables definidas en el servidor antes de renderizar la página.
const name = "Fernando Alberto Herrera Jiménez";
const title = "Home Page";
const currentDate = new Date();
---

<MainLayout title={title}>
  <!-- Título principal visible en la página -->
  <h1>{name}</h1>

  <!-- Este valor se calcula al renderizar el servidor -->
  <p>Momento actual: {currentDate.toLocaleTimeString()}</p>

  <!-- Este texto se actualiza desde JavaScript cuando la página carga -->
  <p id="current-time">Momento actual real:</p>

  <script>
    // Buscamos el párrafo para escribir la hora actual del cliente.
    const currentTimeParagraph = document.querySelector(
      "#current-time",
    ) as HTMLParagraphElement | null;

    // Función que actualiza la hora real del cliente en pantalla.
    const updateCurrentTime = () => {
      if (currentTimeParagraph) {
        currentTimeParagraph.textContent = `Momento actual real: ${new Date().toLocaleTimeString()}`;
      }
    };

    // Mostramos la hora al cargar y luego la refrescamos cada segundo.
    updateCurrentTime();
    setInterval(updateCurrentTime, 1000);
  </script>
</MainLayout>
